{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "installCommand": "npm install --legacy-peer-deps",
    "buildCommand": "npm run build",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}